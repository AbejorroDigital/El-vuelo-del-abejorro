{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://abejorro-digital.rf.gd/el-vuelo-del-abejorro/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests" }
      ]
    }
  ]
}