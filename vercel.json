{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://abejorro-digital.rf.gd/el-vuelo-del-abejorro/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
